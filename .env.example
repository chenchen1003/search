# ChromaDB storage — defaults to ./chroma inside the project folder.
# Set to ~/.local/share/knowledge/chroma to share across projects/OSes.
# CHROMA_DIR=~/.local/share/knowledge/chroma

# Embedding model — GGUF (default) or HuggingFace repo id.
EMBED_MODEL=models/Qwen3-Embedding-0.6B-Q8_0.gguf
# EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B

# Re-ranking LLM — used when --rerank flag is passed.
LLM_MODEL=models/Qwen2.5-Coder-1.5B-Instruct-Q8_0.gguf

CHUNK_SIZE=400
CHUNK_OVERLAP=50
API_PORT=8000
